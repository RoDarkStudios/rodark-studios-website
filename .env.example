AUTH_SECRET=generate-a-long-random-secret
ROBLOX_OAUTH_CLIENT_ID=your-roblox-oauth-client-id
ROBLOX_OAUTH_CLIENT_SECRET=your-roblox-oauth-client-secret
# Optional: defaults to current origin + /api/auth/callback
# ROBLOX_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/callback
# Optional: defaults to "openid profile"
# ROBLOX_OAUTH_SCOPES=openid profile
# Optional: defaults to https://apis.roblox.com/oauth
# ROBLOX_OAUTH_BASE_URL=https://apis.roblox.com/oauth
# Optional: group id used for admin tab visibility (rank >= 254)
# ROBLOX_GROUP_ID=5545660
# Required for admin monetization/config tools
# Must include scopes: game-pass:read, game-pass:write, developer-product:read, developer-product:write, universe:read, universe:write, universe.place:write
ROBLOX_OPEN_CLOUD_API_KEY=your-roblox-open-cloud-api-key

# Required for shared admin Game Configuration storage on Railway Postgres.
DATABASE_URL=postgresql://user:password@host:port/database

# Required for the separate 24/7 Discord bot Railway service.
DISCORD_BOT_TOKEN=your-discord-bot-token
